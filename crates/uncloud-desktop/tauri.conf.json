{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Uncloud",
  "identifier": "de.lunarstream.uncloud",
  "build": {
    "frontendDist": "src-frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "shortDescription": "Self-hosted personal cloud storage",
    "longDescription": "Uncloud is a self-hosted personal cloud storage system for files, photos, and music with file sync, sharing, and in-browser playback.",
    "category": "Utility",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3", "libappindicator-gtk3"]
      }
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/decaychain/uncloud/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3NjdDMDUzMzYyMTIyMTEKUldRUklpRTJVOEJuZHdMNm1vL1FDVVNJQkhvWVBWQmpST2gyUUhwMjl1OXBpNWpGTXJDMmFUYm8K"
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Uncloud",
  "identifier": "de.lunarstream.uncloud",
  "build": {
    "frontendDist": "src-frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/tray-idle.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}

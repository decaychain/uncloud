{
  "$schema": "../node_modules/@tauri-apps/cli/schema/capability.json",
  "identifier": "default",
  "description": "Default capabilities for the Uncloud desktop app",
  "windows": ["main", "browser"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-close",
    "core:tray:default",
    "dialog:default"
  ]
}
